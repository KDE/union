    \li \b header
    \li Set when the tab bar is located in the header of the application.
\row
    \li \b footer
    \li Set when the tab bar is located in the footer of the application.


\endtable



\section2 NavigationTabButton

A button for use in a NavigationTabBar.

\table
\row
    \li \b{Type}
    \li{2, 1} NavigationTabButton

\row
    \li{1, 6} \b{States}
    \li{2, 1} Hovered
\row
    \li{2, 1} ActiveFocus
\row
    \li{2, 1} VisualFocus
