\row
    \li{1, 2} \b{Hints}
    \li \b modal
    \li Used to indicate the overlay is for modal popups.
\row
    \li \b modeless
    \li Used to indicate the overlay is for modeless popups.


\endtable



\section2 Dialog

A popup with a title, content and action buttons.

\table
\row
    \li \b{Type}
    \li{2, 1} Dialog




\endtable

\section3 Sub-Elements

\section4 Header

The label used for the title in the dialog's header.

\table
\row
    \li \b{Type}
    \li{2, 1} Label


\row
    \li{1, 1} \b{Hints}
    \li \b header
    \li Used to indicate this label is used as a header.


\endtable




\section2 DialogButtonBox

A container for dialog action buttons.

\table
\row
    \li \b{Type}
    \li{2, 1} DialogButtonBox



\row
    \li{1, 1} \b{Attributes}
        \li \b position
    \li The position of the dialog button box. \br
        Possible values:
        \list
            \li \b header The dialog button box is in the header of a dialog.
            \li \b footer The dialog button box is in the footer of a dialog.
        \endlist


\endtable

\section3 Sub-Elements

\section4 Delegate

A button that is used to represent each dialog action.

\table
\row
    \li \b{Type}
    \li{2, 1} Button



\row
    \li{1, 1} \b{Attributes}
        \li \b role
    \li The dialog button box role associated with this button. \br
        Possible values:
        \list
            \li \b invalid The button has an invalid role.
            \li \b accept The button is used to accept the dialog.
            \li \b reject The button is used to reject the dialog.
            \li \b destructive The button is used for a destructive action.
            \li \b action The button is used for a generic action.
            \li \b help The button is used to call up some form of help.
            \li \b yes The button is used to confirm the dialog.
            \li \b no The button is used to deny the dialog.
            \li \b reset The button is used to reset the contents of the dialog.
            \li \b apply The button is used to apply the changes made in the dialog.
        \endlist


\endtable




\section2 Menu

A popup containing a list of interactive elements.

\table
\row
    \li \b{Type}
    \li{2, 1} Menu

\row
    \li{1, 2} \b{States}
    \li{2, 1} ActiveFocus
\row
    \li{2, 1} Enabled



\endtable

\section3 Sub-Elements

\section4 Delegate

The default element for menu items is MenuItem. See there for details.





\section2 MenuItem

A single entry in a menu.

\table
\row
    \li \b{Type}
    \li{2, 1} MenuItem

\row
    \li{1, 7} \b{States}
    \li{2, 1} Hovered
\row
    \li{2, 1} ActiveFocus
\row
    \li{2, 1} VisualFocus
\row
    \li{2, 1} Pressed
\row
    \li{2, 1} Checked
\row
    \li{2, 1} Enabled
\row
    \li{2, 1} Highlighted

\row
    \li{1, 2} \b{Hints}
    \li \b exclusive
    \li Set when the menu item is checkable and only a single entry between
multiple menu items can be checked. Generally used to change the
indicator into a radio button style.

\row
    \li \b with-submenu
    \li Set when the menu item will show a submenu on hover or click.


\endtable

\section3 Sub-Elements

\section4 Icon

The icon displayed by the element. Style it using the icon related
properties.




\section4 Text

The text displayed by the element. Style it using the text related
properties.




\section4 ShortcutText

A text that shows what shortcut is assigned to the menu item.

\table
\row
    \li \b{Type}
    \li{2, 1} ShortcutText




\endtable


\section4 Indicator

A rectangle used to display the checkmark for checkable items.

\table
\row
    \li \b{Type}
    \li{2, 1} Indicator




\endtable


\section4 Arrow

An icon used to display an arrow icon when the menu item will show a
sub menu.


\table
\row
    \li \b{Type}
    \li{2, 1} Arrow




\endtable




\section2 MenuSeparator

A separator between different menu items.

\table
\row
    \li \b{Type}
    \li{2, 1} MenuSeparator

\row
    \li{1, 1} \b{States}
    \li{2, 1} Enabled



\endtable



\section2 MenuBar

A bar containing items that will show menus.

\table
\row
    \li \b{Type}
    \li{2, 1} MenuBar




\endtable

\section3 Sub-Elements

\section4 Delegate

The default item used for entries of a menu bar is MenuBarItem.





\section2 MenuBarItem

An item inside a menu bar that will show a menu when clicked.

\table
\row
    \li \b{Type}
    \li{2, 1} MenuBarItem

\row
    \li{1, 7} \b{States}
    \li{2, 1} Hovered
